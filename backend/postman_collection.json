				{ "name": "Create Worker", "request": { "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] }, "method": "POST", "header": [ { "key": "Accept", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n    \"name\": \"Treballador 1\",\n    \"role\": \"Logística\",\n    \"cost_per_hour\": 15.75\n}", "options": { "raw": { "language": "json" } } }, "url": "http://localhost:8000/api/workers" } }
			]
		},
		{
			"name": "Assignments",
			"item": [
				{ "name": "Assign Worker to Event", "request": { "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] }, "method": "POST", "header": [ { "key": "Accept", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n    \"worker_id\": 1\n}", "options": { "raw": { "language": "json" } } }, "url": "http://localhost:8000/api/events/1/workers" } },
				{ "name": "Remove Worker from Event", "request": { "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] }, "method": "DELETE", "header": [ { "key": "Accept", "value": "application/json" } ], "url": "http://localhost:8000/api/events/1/workers/1" } },
				{ "name": "List Workers in Event", "request": { "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] }, "method": "GET", "header": [ { "key": "Accept", "value": "application/json" } ], "url": "http://localhost:8000/api/events/1/workers" } }
			]
		},
		{
			"name": "Flask AI Direct",
			"item": [
				{ "name": "Predict Cost (Direct to Flask)", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [ { "key": "Accept", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n    \"type\": \"wedding\",\n    \"assistants\": 250,\n    \"workers\": 15,\n    \"hours\": 10,\n    \"cost_per_hour\": 20.0\n}", "options": { "raw": { "language": "json" } } }, "url": "http://localhost:5000/predict-cost" } }
			]
